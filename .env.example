# .env.example — Copy this file to .env and fill in your real values.
# Do NOT commit .env — it is in .gitignore.
#
# How to get your Discord Webhook URL:
#   Server Settings > Integrations > Webhooks > New Webhook > Copy Webhook URL

# ─────────────────────────────────────────────────────────────────────────────
# PLACEHOLDER — This is not a real URL. Replace both values before use.
# YOUR_WEBHOOK_ID    → the numeric ID in your Discord webhook URL
# YOUR_WEBHOOK_TOKEN → the token string in your Discord webhook URL
# ─────────────────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
